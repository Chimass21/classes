APP_NAME=Brain4
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===================================================================
# AI Content Generation — OpenAI-compatible API
# ===================================================================
# This enables AI-powered lesson plans, lesson notes & question generation.
# Without it, the app uses a built-in template-based generator (still works).
#
# Cerebras (30 RPM, 1M tokens/day, no CC): https://cloud.cerebras.ai
# Groq (30 RPM, 1000 req/day, no CC):       https://console.groq.com/keys
# DeepSeek (5M free tokens, no CC):         https://platform.deepseek.com/api_keys
# GitHub Models (requires GH account):      https://github.com/marketplace/models
# ===================================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.cerebras.ai
OPENAI_MODEL=zai-glm-4.7
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=120
